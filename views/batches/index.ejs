<%- include('../header', { title: 'Batches' }) %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-800">Batches</h1>
  <a href="/batches/new" class="btn btn-primary">+ New Batch</a>
</div>

<!-- Filters -->
<div class="mb-4 space-y-2">
  <div class="flex flex-wrap gap-2">
    <% statuses.forEach(s => { %>
      <button class="filter-pill <%= filters.status === s ? 'active' : '' %>"
              data-filter="<%= s %>" data-filter-group="status">
        <%= s %>
      </button>
    <% }) %>
  </div>
  <div class="flex flex-wrap gap-2 items-center">
    <select onchange="updateFilters('variety_id', this.value)" class="form-input w-auto text-sm">
      <option value="">All Varieties</option>
      <% varieties.forEach(v => { %>
        <option value="<%= v.id %>" <%= filters.variety_id == v.id ? 'selected' : '' %>><%= v.name %></option>
      <% }) %>
    </select>
    <select onchange="updateFilters('location_id', this.value)" class="form-input w-auto text-sm">
      <option value="">All Locations</option>
      <% locations.forEach(l => { %>
        <option value="<%= l.id %>" <%= filters.location_id == l.id ? 'selected' : '' %>><%= l.name %></option>
      <% }) %>
    </select>
    <span class="text-sm text-gray-500 ml-1">Seed date:</span>
    <input type="date" class="form-input w-auto text-sm"
           value="<%= filters.date_from || '' %>"
           onchange="updateFilters('date_from', this.value)">
    <span class="text-sm text-gray-500">to</span>
    <input type="date" class="form-input w-auto text-sm"
           value="<%= filters.date_to || '' %>"
           onchange="updateFilters('date_to', this.value)">
  </div>
</div>

<% if (batches.length === 0) { %>
  <div class="empty-state">
    <div class="empty-state-icon">&#127793;</div>
    <p class="text-lg font-medium text-gray-600 mb-2">No batches found</p>
    <% if (filters.status || filters.variety_id || filters.location_id || filters.date_from || filters.date_to) { %>
      <p class="mb-4">Try clearing your filters.</p>
      <a href="/batches" class="btn btn-secondary">Clear Filters</a>
    <% } else { %>
      <p class="mb-4">Create your first planting batch to start tracking.</p>
      <a href="/batches/new" class="btn btn-primary">+ New Batch</a>
    <% } %>
  </div>
<% } else { %>
  <div class="grid gap-3">
    <% batches.forEach(b => { %>
      <a href="/batches/<%= b.id %>" class="card card-hover block">
        <div class="flex items-start justify-between gap-4">
          <div class="min-w-0">
            <div class="flex items-center gap-2 flex-wrap">
              <span class="font-mono text-sm text-gray-500"><%= b.batch_code %></span>
              <span class="badge badge-<%= b.status %>"><%= b.status %></span>
            </div>
            <h3 class="font-semibold text-gray-800 mt-1"><%= b.variety_name %></h3>
            <div class="flex gap-3 text-sm text-gray-500 mt-1">
              <% if (b.location_name) { %>
                <span><%= b.location_name %></span>
              <% } %>
              <% if (b.quantity) { %>
                <span><%= b.quantity %> plants</span>
              <% } %>
              <% if (b.season) { %>
                <span><%= b.season %> <%= b.year %></span>
              <% } %>
            </div>
          </div>
          <div class="text-right text-xs text-gray-400 shrink-0">
            <% if (b.planned_seed_date) { %>
              <div>Plan: <%= b.planned_seed_date %></div>
            <% } %>
            <% if (b.actual_seed_date) { %>
              <div>Seeded: <%= b.actual_seed_date %></div>
            <% } %>
          </div>
        </div>
      </a>
    <% }) %>
  </div>
<% } %>

<%- include('../footer') %>

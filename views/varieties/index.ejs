<%- include('../header', { title: 'Varieties' }) %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-800">Varieties</h1>
  <a href="/varieties/new" class="btn btn-primary">+ Add Variety</a>
</div>

<div class="mb-4">
  <input type="text" id="variety-search" placeholder="Search varieties..." class="form-input max-w-sm">
</div>

<% if (varieties.length === 0) { %>
  <div class="empty-state">
    <div class="empty-state-icon">&#127801;</div>
    <p class="text-lg font-medium text-gray-600 mb-2">No varieties yet</p>
    <p class="mb-4">Add your first flower variety to get started.</p>
    <a href="/varieties/new" class="btn btn-primary">+ Add Variety</a>
  </div>
<% } else { %>
  <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
    <% varieties.forEach(v => { %>
      <a href="/varieties/<%= v.id %>/edit" class="card card-hover block variety-item">
        <div class="flex items-start justify-between">
          <div>
            <h3 class="font-semibold text-gray-800"><%= v.name %></h3>
            <div class="flex gap-2 mt-1 flex-wrap">
              <% if (v.type) { %>
                <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full"><%= v.type %></span>
              <% } %>
              <% if (v.color) { %>
                <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full"><%= v.color %></span>
              <% } %>
            </div>
          </div>
          <% if (v.pinch) { %>
            <span class="text-xs bg-amber-100 text-amber-700 px-2 py-0.5 rounded-full">Pinch</span>
          <% } %>
        </div>
        <% if (v.days_to_bloom) { %>
          <p class="text-xs text-gray-400 mt-2"><%= v.days_to_bloom %> days to bloom</p>
        <% } %>
      </a>
    <% }) %>
  </div>
<% } %>

<script>setupSearch('variety-search', '.variety-item');</script>

<%- include('../footer') %>
